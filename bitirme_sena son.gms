s(i)  = 40;
et(i) = 480;
lt(i) = 1020;

s("n1")  = 0;
et("n1") = 0;
lt("n1") = 1440;
A(i,t)$(ord(i) ne 1) = 1 ;

Variables
    Z 'Toplam katedilen mesafe (km)';

Binary Variables
    X(i,j,k,r,t) 'k aracı, t gününde, r. seferinde i den j ye gidiyorsa 1, aksi halde 0';

Positive Variables
    V(i,k,r,t) 'k aracının t gününde r. seferinde i düğümüne varış zamanı (dk)'
    u(i,k,r,t) 'Kapasite takibi ve alt-tur engelleme için yardımcı değişken';
    
Equations
    ObjFunc                   'Amaç Fonksiyonu: Toplam mesafeyi minimize et'
    ZiyaretKisit(i,t)         'Planlanan her gün her siteye mutlaka bir araç/sefer uğramalıdır'
    AkimDengesi(j,k,r,t)      'Bir siteye giren araç, o siteden çıkmalıdır'
    Kapasite(k,r,t)           'Her bir seferde toplanan toplam atık araç kapasitesini aşamaz'
    SeferSirasi(k,r,t)        'r+1. sefere başlamak için r. seferin tamamlanıp depoya dönülmesi gerekir'
    ZamanPenceresi(i,j,k,r,t) 'Varış zamanı hesaplama ve alt-tur engelleme'
    ZamanAltSinir(i,k,r,t)    'Mesai başlangıç kısıtı'
    ZamanUstSinir(i,k,r,t)    'Mesai bitiş kısıtı'
    GunlukSure(k,t)           'Bir aracın günlük maksimum çalışma süresi kısıtı'
    AltTurEngelleme(i,j,k,r,t) 'Alt-tur engelleme kısıtı';



ObjFunc..
    Z =e= sum((t,k,r,i,j), d(i,j) * X(i,j,k,r,t));

ZiyaretKisit(i,t)$(ord(i) ne 1)..
    sum((k,r,j)$(ord(j) ne ord(i)), X(i,j,k,r,t)) =e= A(i,t);
    
AkimDengesi(j,k,r,t)..
    sum(i$(ord(i) ne ord(j)), X(i,j,k,r,t)) - sum(l$(ord(l) ne ord(j)), X(j,l,k,r,t)) =e= 0;

Kapasite(k,r,t)..
   sum((i,j)$(ord(i) ne 1), q(i,t)*X(i,j,k,r,t)) =l= C;
   
SeferSirasi(k,r,t)$(ord(r) < card(r))..
    sum(j$(ord(j) ne 1), X("n1",j,k,r+1,t)) =l= sum(i$(ord(i) ne 1), X(i,"n1",k,r,t));

ZamanPenceresi(i,j,k,r,t)$(ord(i) ne ord(j))..
    V(i,k,r,t) + s(i) + tt(i,j) =l= V(j,k,r,t) + M * (1 - X(i,j,k,r,t));
    
ZamanAltSinir(i,k,r,t)..
    V(i,k,r,t) =g= et(i);
    
ZamanUstSinir(i,k,r,t)..
    V(i,k,r,t) =l= lt(i);
    
GunlukSure(k,t)..
    sum((r,i,j), (tt(i,j) + s(i)) * X(i,j,k,r,t)) =l= Tmax;

AltTurEngelleme(i,j,k,r,t)$(ord(i) > 1 and ord(j) > 1 and ord(i) <> ord(j))..
    u(i,k,r,t) - u(j,k,r,t) + C * X(i,j,k,r,t) =l= C - q(j,t);

    
Model bitirme_sena /all/;
Solve bitirme_sena using MIP minimizing Z;