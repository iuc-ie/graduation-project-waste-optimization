Sets
    i 'Dugumler (0: Depo, 1..n: Sanayi Siteleri)' /n1*n37/
    k 'Cop toplama araclari' /1*8/
    r 'Gun ici sefer numaralari' /1*2/
    t 'Haftalık planlama gunleri (1:Pzt..6:Cmt)' /T1*T6/;
    
Alias (i,j,l);

Parameters
    d(i,j) 'i ve j noktalari arasi mesafe (km)'
    tt(i,j) 'i ve j noktalari arasi seyahat suresi (dk)'
    q(i,t) 't gununde i sitesindeki atik miktari (br)'
    s(i) 'i sitesinde konteyner bosaltma suresi (dk)'
    et(i) 'i sitesi icin servis penceresi baslangici (mesai baslangic) (dk)'
    lt(i) 'i sitesi icin servis penceresi bitisi (mesai bitis) (dk)'
    A(i,t) 'Atama parametresi (1: ugranacak, 0: ugranmayacak)'
    ;
    
Scalars
    C 'Bir aracin maksimum tasima kapasitesi (br)' /130000/
    Tmax 'Bir aracin gunluk toplam calisma suresi siniri (dk)' /480/
    M 'Cok buyuk bir pozitif sayi' /20000/
    ;

    
